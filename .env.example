# ─── Nobana environment ───────────────────────────────────
# Copy to .env and fill in real values. Never commit .env.

# PostgreSQL connection string.
# For the bundled dev database (docker compose -f docker-compose.dev.yml up -d):
DATABASE_URL="postgresql://nobana:nobana@localhost:5432/nobana_db?schema=public"

# Secret used to sign admin session JWTs. Use a long random value, e.g.:
#   openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret"

# Seed admin credentials (used by `npm run db:seed`).
ADMIN_EMAIL="admin@nobana.ir"
ADMIN_PASSWORD="change-this-strong-password"

# Public site URL (used for metadata / absolute links).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
